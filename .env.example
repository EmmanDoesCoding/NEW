# AVA Sign Language API — Environment Variables
# Copy this file to .env and fill in your values.
# Load with:  export $(cat .env | xargs)
# Or use python-dotenv if you prefer.

# OpenRouter API key (required for /chatbot and Tagalog API fallback)
# Get yours free at https://openrouter.ai
OPENROUTER_API_KEY=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

# Model to use (Gemma 3 4B free tier — same as the desktop app)
OPENROUTER_MODEL=google/gemma-3-4b-it:free

# Absolute path to your Signs/ folder (defaults to ./Signs/ next to api.py)
# SIGNS_FOLDER=/path/to/your/Signs
